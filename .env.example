# ================================================================
# Meridian — environment variables
# ================================================================
# Secret keys must NOT be prefixed with VITE_ — they are read only by
# Vercel Edge Functions in /api/*.ts and never shipped to the client.
# Client-safe feature flags can use VITE_PUBLIC_*.
# ================================================================

# --- Phase 1: Globe -----------------------------------------------

# Google Maps Platform API key with "Map Tiles API" enabled.
# https://console.cloud.google.com → APIs & Services → Credentials
# Restrict by HTTP referrer to your Vercel preview + production URLs.
GOOGLE_MAPS_3D_TILES_KEY=

# Cesium Ion default access token. Used as fallback when Google 3D
# Tiles are unavailable, and for terrain.
# https://cesium.com/ion/tokens
VITE_PUBLIC_CESIUM_ION_TOKEN=

# Feature flag: true when a Google 3D Tiles key is configured on the
# server. Client uses this to decide whether to request tiles from
# /api/tiles-proxy or fall back to Cesium Ion.
VITE_PUBLIC_HAS_GOOGLE_TILES=false

# Local-dev only fallback: when running `pnpm dev` without a Vercel edge
# function, set this to your Google key so Cesium can request tiles
# directly. NEVER set this in production — it ships to the client bundle.
VITE_PUBLIC_GOOGLE_TILES_DEV_KEY=

# --- Phase 2: Vessels + Aircraft ---------------------------------

# AISStream.io WebSocket API key. This one is client-side because
# WebSocket proxying through Vercel Edge is impractical — and AISStream
# explicitly supports client-side keys on their free tier. Rotate it if
# it leaks.
# https://aisstream.io → register for free account
VITE_PUBLIC_AISSTREAM_KEY=

# OpenSky Network OAuth2 client credentials. Used ONLY by
# /api/opensky-proxy (server-side) — the proxy exchanges these for a
# bearer token against Keycloak and caches it across requests. Never
# shipped to the client.
# https://opensky-network.org/my-opensky/account → "API Client"
OPENSKY_CLIENT_ID=
OPENSKY_CLIENT_SECRET=

# --- Phase 5+: additional (optional) -----------------------------
# No keys required — NOAA NWS, Open-Meteo, IMB Piracy RSS, CelesTrak are all open.
